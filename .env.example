# MongoDB connection string. Copy this file to .env.local and set your URI.
# Local:   mongodb://127.0.0.1:27017/zero-to-hundred
# Atlas:   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/zero-to-hundred?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/zero-to-hundred

# Cloudinary — stores uploaded images/videos. Get these from your
# Cloudinary Dashboard (https://cloudinary.com/console).
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Optional: folder assets are stored under (defaults to 0to100-tracker)
CLOUDINARY_FOLDER=0to100-tracker

# Admin auth — the passcode unlocks add/edit/delete (viewing stays public).
ADMIN_PASSCODE=set-a-strong-passcode
# Secret used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-a-long-random-string

# Auto-fill specs — optional. FREE Google Gemini key (no card) for the
# "Auto-fill from web" button on the car form and for the specs generated when
# cars are imported from the Google Sheet. Lookups are grounded in live Google
# Search results (free tier). Get a key at:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override (defaults to gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash

# Google Sheet two-way sync — optional. See docs/SHEET_SYNC_SETUP.md.
# Shared secret between the site and the sheet's Apps Script. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SHEET_SYNC_SECRET=
# The Apps Script web app URL (ends in /exec) — used to push the leaderboard
# back into the sheet after cars change on the site.
SHEET_WEBAPP_URL=
